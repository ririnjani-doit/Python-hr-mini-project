      "source": [
        "candidates = [\n",
        "\n",
        "    {\n",
        "        \"name\": \"Andi\",\n",
        "        \"education\": \"Bachelor\",\n",
        "        \"experience\": 2,\n",
        "        \"english\": 85,\n",
        "        \"python\": 70\n",
        "    },\n",
        "\n",
        "    {\n",
        "        \"name\": \"Budi\",\n",
        "        \"education\": \"Diploma\",\n",
        "        \"experience\": 1,\n",
        "        \"english\": 60,\n",
        "        \"python\": 55\n",
        "    },\n",
        "    {\n",
        "        \"name\": \"Cici\",\n",
        "        \"education\": \"Bachelor\",\n",
        "        \"experience\": 3,\n",
        "        \"english\": 90,\n",
        "        \"python\": 88\n",
        "    },\n",
        "    {\n",
        "        \"name\": \"Dina\",\n",
        "        \"education\": \"Master\",\n",
        "        \"experience\": 5,\n",
        "        \"english\": 92,\n",
        "        \"python\": 80\n",
        "    },\n",
        "    {\n",
        "        \"name\": \"Eka\",\n",
        "        \"education\": \"Bachelor\",\n",
        "        \"experience\": 0,\n",
        "        \"english\": 72,\n",
        "        \"python\": 65\n",
        "    },\n",
        "    {\n",
        "        \"name\": \"Farhan\",\n",
        "        \"education\": \"Bachelor\",\n",
        "        \"experience\": 4,\n",
        "        \"english\": 78,\n",
        "        \"python\": 85\n",
        "    }\n",
        "]\n",
        "\n",
        "def calculate_score(candidate):\n",
        "     exp_conversion = candidate[\"experience\"]*20\n",
        "     if candidate[\"experience\"]>=5:\n",
        "        exp_conversion = 100\n",
        "\n",
        "     english_score = candidate[\"english\"] *0.4\n",
        "     python_score = candidate[\"python\"]*0.4\n",
        "     experience_score = exp_conversion*0.2\n",
        "     total_score = english_score + python_score + experience_score\n",
        "     return total_score\n",
        "\n",
        "def get_status(score):\n",
        "    if score>=85:\n",
        "      return \"Highly Recommended\"\n",
        "    elif 70<=score<=84:\n",
        "      return \"Recommended\"\n",
        "    elif 60<=score<=69:\n",
        "      return \"Consider\"\n",
        "    else:\n",
        "      return \"Not Recommended\"\n",
        "\n",
        "print(\"======================================\")\n",
        "print(\"          CANDIDATE REPORT             \")\n",
        "print(\"======================================\")\n",
        "\n",
        "for candidate in candidates:\n",
        "  final_score = calculate_score(candidate)\n",
        "  final_status = get_status(final_score)\n",
        "  candidate[\"score\"] = final_score\n",
        "  candidate[\"status\"] = final_status\n",
        "  print(\"======================================\")\n",
        "  print(f\"Nama     : {candidate['name']}\")\n",
        "  print(f\"Education: {candidate['education']}\")\n",
        "  print(f\"Score    : {final_score}\")\n",
        "  print(f\"status   : {final_status}\")\n",
        "  print(\"======================================\")\n",
        "\n",
        "\n",
        "\n"
      ]
    },
    {
